# =============================================
# SPKLU Backend — .env untuk PRODUKSI
# =============================================
# Salin file ini ke .env di VPS:
#   cp .env.production.example .env
# Lalu isi nilai yang benar. Backend akan MENOLAK jalan (exit 1)
# jika NODE_ENV=production dan salah satu dari ini tidak dipenuhi:
#   - JWT_SECRET < 32 karakter atau mengandung string 'ganti-dengan'
#   - DB_PASSWORD kosong
# Ini disengaja — fail-fast mencegah produksi jalan dengan credential default.

NODE_ENV=production
PORT=3001

# ---- Database ----
# JANGAN pakai root. Gunakan user 'spklu' yang dibuat via deploy/db-setup.sql.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=spklu
DB_PASSWORD=GANTI_DENGAN_PASSWORD_KUAT_MIN_16_CHAR
DB_NAME=spklu_db

# ---- JWT ----
# Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Hasil ~64 karakter. JANGAN commit ke git.
JWT_SECRET=GANTI_DENGAN_HASIL_GENERATE_MINIMAL_32_CHAR
JWT_EXPIRES=7d

# ---- CORS ----
# Origin frontend yang diizinkan. Gunakan domain HTTPS produksi.
# Contoh: https://spklu.cmw-charger.co.id
# Jika akses via IP saja (belum ada domain), pakai: http://IP_VPS_ANDA
CORS_ORIGIN=https://GANTI_DENGAN_DOMAIN_ANDA
